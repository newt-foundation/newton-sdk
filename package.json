{
  "name": "@magicnewton/newton-protocol-sdk",
  "version": "0.3.18",
  "description": "Official SDK for the Newton Protocol.",
  "author": "Newton Foundation <https://x.com/newtfoundation> (https://newton.foundation)",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newt-foundation/newton-sdk.git"
  },
  "license": "MIT",
  "homepage": "https://newton.foundation",
  "target": "browser",
  "cdnGlobalName": "NewtonSdk",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts",
      "import": "./dist/es/types/index.js",
      "require": "./dist/cjs/types/index.js"
    },
    "./viem": {
      "types": "./dist/types/viem/index.d.ts",
      "import": "./dist/es/viem/index.js",
      "require": "./dist/cjs/viem/index.js"
    },
    "./networks": {
      "types": "./dist/types/networks/index.d.ts",
      "import": "./dist/es/networks/index.js",
      "require": "./dist/cjs/networks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "build": "rollup -c rollup.config.mjs",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync-abis": "./scripts/sync-abis.sh",
    "clean": "rimraf dist && rimraf node_modules"
  },
  "auto": {
    "plugins": [
      "npm",
      "released",
      "conventional-commits"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/rimraf": "^4.0.5",
    "builtin-modules": "^4.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.48.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-node-externals": "^8.1.0",
    "rollup-plugin-tsc-alias": "^1.1.4",
    "rollup-plugin-typescript2": "^0.36.0",
    "@auto-it/conventional-commits": "^11.3.0",
    "auto": "^11.3.0",
    "simple-git-hooks": "^2.11.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "eventemitter3": "^4.0.4",
    "jose": "^6.0.13",
    "viem": "^2.35.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint"
  },
  "externals": {
    "exclude": [
      "eventemitter3",
      "localforage"
    ]
  }
}
