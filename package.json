{
  "name": "@magicnewton/newton-protocol-sdk",
  "version": "0.3.15",
  "description": "Official SDK for the Newton Protocol.",
  "author": "Newton Foundation <https://x.com/newtfoundation> (https://newton.foundation)",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newt-foundation/newton-sdk.git"
  },
  "license": "MIT",
  "homepage": "https://newton.foundation",
  "target": "browser",
  "cdnGlobalName": "NewtonSdk",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts",
      "import": "./dist/es/types/index.js",
      "require": "./dist/cjs/types/index.js"
    },
    "./viem": {
      "types": "./dist/types/viem/index.d.ts",
      "import": "./dist/es/viem/index.js",
      "require": "./dist/cjs/viem/index.js"
    },
    "./networks": {
      "types": "./dist/types/networks/index.d.ts",
      "import": "./dist/es/networks/index.js",
      "require": "./dist/cjs/networks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "build": "rollup -c rollup.config.mjs",
    "lint": "eslint --fix --ext .ts,.tsx .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"No unit tests... yet :(\" && exit 0",
    "clean": "rimraf dist && rimraf node_modules"
  },
  "auto": {
    "plugins": [
      "npm",
      "released",
      "conventional-commits"
    ]
  },
  "devDependencies": {
    "@auto-it/conventional-commits": "^11.2.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/rimraf": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "auto": "^11.1.2",
    "builtin-modules": "^4.0.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.48.1",
    "rollup-plugin-esbuild": "^6.1.1",
    "rollup-plugin-node-externals": "^8.1.0",
    "rollup-plugin-tsc-alias": "^1.1.4",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "eventemitter3": "^4.0.4",
    "jose": "^6.0.13",
    "viem": "^2.35.1"
  },
  "externals": {
    "exclude": [
      "eventemitter3",
      "localforage"
    ]
  }
}
